{% extends 'base.html.twig' %}

{% block title %}Task index{% endblock %}

{% block body %}
    <div class="container">

    <h1>Task index</h1>

        <ul class="nav nav-tabs">
            <li class="nav-item">
                <a class="nav-link active" aria-current="page" href="{{ path('task_index') }}">All</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="{{ path('task_index', {status: "To Do" })}}">To Do</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="{{ path('task_index', {status: "Completed" })}}">Completed</a>
            </li>
        </ul>

    <section>
        <div>
        <a class="btn btn-primary" href="{{ path('task_new') }}">Create new Task</a>
        </div>
        <div class="d-flex flex-wrap gap-5">
            {% for task in tasks %}
                {{ include('partials/_card.html.twig', {'task': task}) }}
            {% else %}
                <p> no task yet!</p>
            {% endfor %}
        </div>
    </div>
{% endblock %}
